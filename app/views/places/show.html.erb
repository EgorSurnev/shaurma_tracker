<%= turbo_frame_tag dom_id(@place) do %>
  <div class="container mx-auto px-4 py-8 max-w-4xl">
    <!-- Кнопка назад -->
    <%= link_to places_path, 
        class: "inline-flex items-center gap-2 text-amber-600 hover:text-amber-700 mb-6 transition-colors" do %>
      <span>←</span> Назад к списку
    <% end %>
    
    <!-- Карточка шаурмечной -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
      <!-- Фото-шапка -->
      <div class="h-64 bg-gradient-to-r from-amber-400 to-orange-500 flex items-center justify-center relative">
        <span class="text-8xl">🥙</span>
        <% if user_signed_in? && (current_user.admin? || @place.user == current_user) %>
          <div class="absolute top-4 right-4">
            <%= link_to edit_place_path(@place), 
                class: "bg-white bg-opacity-90 hover:bg-opacity-100 p-2 rounded-lg transition-all shadow-md" do %>
              ✏️ Редактировать
            <% end %>
          </div>
        <% end %>
      </div>
      
      <div class="p-6 md:p-8">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2"><%= @place.name %></h1>
        <p class="text-gray-600 mb-4 flex items-center gap-2">
          <span class="text-xl">📍</span> <%= @place.address %>
        </p>
        
        <!-- Ссылка на карту -->
        <% if @place.location_url.present? %>
          <%= link_to @place.location_url, target: "_blank", 
              class: "inline-flex items-center gap-1 text-blue-600 hover:text-blue-700 text-sm mb-6" do %>
            🗺 Открыть карту →
          <% end %>
        <% end %>
        
        <!-- Большой рейтинг -->
        <div class="bg-gray-50 rounded-xl p-4 mb-6">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div>
              <span class="text-gray-600 text-sm">Средняя оценка</span>
              <div class="flex items-center gap-2 mt-1">
                <div class="flex text-2xl text-yellow-400">
                  <% (@place.average_rating.to_i).times do %>
                    <span>★</span>
                  <% end %>
                  <% (5 - @place.average_rating.to_i).times do %>
                    <span class="text-gray-300">★</span>
                  <% end %>
                </div>
                <span class="text-2xl font-bold text-gray-800"><%= @place.average_rating %>/5</span>
              </div>
            </div>
            <div class="text-gray-500 text-sm">
              на основе <%= @place.reviews.count %> <%= Russian.p(@place.reviews.count, "отзыва", "отзывов", "отзывов") %>
            </div>
          </div>
        </div>
        
        <!-- Кнопка для открытия модалки -->
        <% if user_signed_in? %>
          <button data-action="click->modal#open" 
                  class="w-full sm:w-auto bg-green-500 hover:bg-green-600 text-white font-semibold px-6 py-3 rounded-lg transition-colors shadow-md flex items-center justify-center gap-2">
            <span class="text-xl">✍️</span>
            Написать отзыв
          </button>
        <% end %>
        
        <!-- Секция с отзывами -->
        <div class="mt-10">
          <h2 class="text-2xl font-bold text-gray-800 mb-4 flex items-center gap-2">
            <span>💬</span> Отзывы
          </h2>
          
          <div id="reviews">
            <% if @place.reviews.any? %>
              <div class="space-y-4">
                <%= render @place.reviews %>
              </div>
            <% else %>
              <div class="text-center py-8 bg-gray-50 rounded-xl">
                <span class="text-4xl mb-2 block">😢</span>
                <p class="text-gray-500">Пока никто не оставил отзыв</p>
                <p class="text-gray-400 text-sm">Стань первым!</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Модальное окно -->
  <div data-controller="modal" 
       data-modal-target="modal" 
       class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4"
       data-action="click->modal#backdropClick">
    <div class="bg-white rounded-xl max-w-md w-full mx-auto shadow-2xl transform transition-all">
      <div class="flex justify-between items-center p-6 border-b">
        <h3 class="text-2xl font-bold text-gray-800">Новый отзыв</h3>
        <button data-action="modal#close" 
                class="text-gray-400 hover:text-gray-600 text-3xl leading-none transition-colors">
          &times;
        </button>
      </div>
      
      <div class="p-6">
        <%= form_with(model: [@place, Review.new], 
                      local: false,
                      class: "space-y-4",
                      data: { 
                        controller: "reviews",
                        action: "turbo:submit-end->reviews#reset turbo:submit-end->modal#close"
                      }) do |f| %>
          
          <!-- Рейтинг звездами -->
          <div>
            <%= f.label :rating, "Ваша оценка", class: "block text-gray-700 font-medium mb-2" %>
            <div class="flex gap-2" data-controller="rating">
              <% (1..5).each do |star| %>
                <button type="button" 
                        data-action="rating#set" 
                        data-value="<%= star %>"
                        class="text-4xl text-gray-300 hover:text-yellow-400 transition-all transform hover:scale-110">
                  ★
                </button>
              <% end %>
            </div>
            <%= f.hidden_field :rating, data: { rating_target: "input" }, required: true %>
          </div>
          
          <!-- Текст отзыва -->
          <div>
            <%= f.label :content, "Комментарий", class: "block text-gray-700 font-medium mb-2" %>
            <%= f.text_area :content, 
                rows: 4, 
                placeholder: "Как вам мясо? А соус?",
                class: "w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all",
                required: true %>
          </div>
          
          <div class="flex gap-3 pt-2">
            <%= f.submit "Опубликовать отзыв", 
                class: "flex-1 bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 rounded-lg transition-colors" %>
            <button type="button" 
                    data-action="modal#close" 
                    class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors">
              Отмена
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>