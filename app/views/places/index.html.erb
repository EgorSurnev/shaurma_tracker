<div class="container mx-auto px-4 py-8 max-w-7xl">
  <!-- Header -->
  <header class="flex flex-col md:flex-row justify-between items-center mb-8 pb-4 border-b-2 border-amber-200">
    <div class="flex items-center gap-2 mb-4 md:mb-0">
      <span class="text-4xl">🌯</span>
      <h1 class="text-3xl font-bold text-gray-800">Шаурма-Ростов</h1>
    </div>
    
    <div class="flex gap-3 items-center">
      <% if user_signed_in? %>
        <span class="text-sm text-gray-600">👤 <%= current_user.email %></span>
        <%= link_to "Выйти", destroy_user_session_path, 
            data: { turbo_method: :delete },
            class: "text-sm text-red-600 hover:text-red-800 transition-colors" %>
      <% else %>
        <%= link_to "Войти", new_user_session_path, 
            class: "text-amber-600 hover:text-amber-700 font-medium" %>
        <span class="text-gray-300">|</span>
        <%= link_to "Регистрация", new_user_registration_path, 
            class: "text-amber-600 hover:text-amber-700 font-medium" %>
      <% end %>
    </div>
  </header>

  <!-- Кнопка добавления -->
  <% if user_signed_in? %>
    <div class="mb-6">
      <%= link_to new_place_path, 
          class: "inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold px-6 py-3 rounded-lg transition-colors shadow-md hover:shadow-lg" do %>
        <span class="text-xl">➕</span>
        Добавить новую точку
      <% end %>
    </div>
  <% end %>

  <!-- Grid карточек -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @places.each do |place| %>
      <!-- Turbo Frame для каждой карточки -->
      <%= turbo_frame_tag dom_id(place) do %>
        <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
          <!-- Фото-заглушка с эмодзи -->
          <div class="h-48 bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center relative">
            <span class="text-7xl">🥙</span>
            <% if user_signed_in? && (current_user.admin? || place.user == current_user) %>
              <div class="absolute top-2 right-2 flex gap-1">
                <%= link_to edit_place_path(place), 
                    class: "bg-white bg-opacity-90 p-1 rounded-lg hover:bg-opacity-100 transition-all" do %>
                  <span class="text-sm">✏️</span>
                <% end %>
                <%= link_to place_path(place), 
                    data: { turbo_method: :delete, turbo_confirm: "Удалить эту точку и все отзывы?" },
                    class: "bg-white bg-opacity-90 p-1 rounded-lg hover:bg-opacity-100 transition-all" do %>
                  <span class="text-sm">🗑</span>
                <% end %>
              </div>
            <% end %>
          </div>
          
          <div class="p-5">
            <h2 class="text-xl font-bold text-gray-800 mb-2 line-clamp-1">
              <%= link_to place.name, place_path(place), 
                  class: "hover:text-amber-600 transition-colors" %>
            </h2>
            
            <p class="text-gray-600 text-sm mb-3 line-clamp-2 flex items-start gap-1">
              <span class="text-base">📍</span> <%= place.address %>
            </p>
            
            <!-- Рейтинг звездами -->
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-1">
                <div class="flex text-yellow-400">
                  <% (place.average_rating.to_i).times do %>
                    <span>★</span>
                  <% end %>
                  <% (5 - place.average_rating.to_i).times do %>
                    <span class="text-gray-300">★</span>
                  <% end %>
                </div>
                <span class="text-sm text-gray-500 ml-2">
                  <%= place.average_rating %>/5
                </span>
              </div>
              <span class="text-xs text-gray-400">
                📝 <%= place.reviews.count %> отзывов
              </span>
            </div>
            
            <%= link_to "Подробнее →", place_path(place), 
                class: "inline-block w-full text-center bg-gray-100 hover:bg-amber-500 text-gray-700 hover:text-white font-medium py-2 rounded-lg transition-colors" %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>