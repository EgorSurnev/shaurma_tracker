<!DOCTYPE html>
<html>
  <head>
    <title>🐸 Секретная страница 🐸</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        min-height: 100vh;
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: system-ui, -apple-system, sans-serif;
        cursor: pointer;
      }
      
      .frog-container {
        text-align: center;
        animation: float 3s ease-in-out infinite;
      }
      
      .frog-emoji {
        font-size: 40vw;
        display: block;
        animation: bounce 0.5s ease-in-out infinite;
        filter: drop-shadow(0 0 20px rgba(0,255,0,0.3));
      }
      
      .number {
        font-size: 15vw;
        font-weight: 900;
        color: #4ade80;
        text-shadow: 0 0 20px rgba(74,222,128,0.5);
        margin-top: 2rem;
        animation: pulse 1s ease-in-out infinite;
        letter-spacing: 0.1em;
      }
      
      .subtitle {
        font-size: 1rem;
        color: #22c55e;
        margin-top: 2rem;
        opacity: 0.7;
        font-family: monospace;
      }
      
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
      }
      
      @keyframes bounce {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
      }
      
      @keyframes pulse {
        0%, 100% { opacity: 1; text-shadow: 0 0 20px rgba(74,222,128,0.5); }
        50% { opacity: 0.7; text-shadow: 0 0 40px rgba(74,222,128,0.8); }
      }
      
      .back-link {
        position: fixed;
        bottom: 20px;
        left: 20px;
        color: #4ade80;
        text-decoration: none;
        font-size: 0.875rem;
        opacity: 0.5;
        transition: opacity 0.3s;
      }
      
      .back-link:hover {
        opacity: 1;
      }
    </style>
  </head>
  <body onclick="window.location.href='/'">
    <div class="frog-container">
      <span class="frog-emoji">🐸</span>
      <div class="number">67</div>
      <div class="subtitle">нажми в любом месте, чтобы вернуться</div>
    </div>
    
    <a href="/" class="back-link">← Вернуться на главную</a>
    
    <script>
      // Консольное приветствие для самых внимательных
      console.log("🐸 67 — ты нашёл пасхалку! 🐸");
    </script>
  </body>
</html>