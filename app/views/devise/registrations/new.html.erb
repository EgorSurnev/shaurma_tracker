<div class="bg-white rounded-2xl shadow-2xl overflow-hidden transform transition-all duration-300 hover:scale-[1.02]">
  <!-- Шапка с мясным градиентом -->
  <div class="bg-gradient-to-r from-red-700 via-red-600 to-amber-700 px-6 py-8 text-center">
    <div class="text-7xl mb-3 animate-bounce">🥩</div>
    <h1 class="text-3xl font-bold text-white mb-2">Создать аккаунт</h1>
    <p class="text-amber-100 text-sm">Присоединяйся к сообществу шаурма-гурманов!</p>
  </div>
  
  <!-- Форма регистрации -->
  <div class="p-6 md:p-8">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), 
        html: { class: "space-y-5" }) do |f| %>
      
      <!-- Ошибки валидации -->
      <%= render "devise/shared/error_messages", resource: resource %>
      
      <!-- Email -->
      <div>
        <%= f.label :email, class: "block text-gray-700 font-semibold mb-2 flex items-center gap-2" do %>
          <span class="text-xl">📧</span>
          Email
        <% end %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 transition-all",
            placeholder: "shaurma@love.com",
            required: true %>
      </div>
      
      <!-- Пароль -->
      <div>
        <%= f.label :password, class: "block text-gray-700 font-semibold mb-2 flex items-center gap-2" do %>
          <span class="text-xl">🔒</span>
          Пароль
        <% end %>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 transition-all",
            placeholder: "••••••••",
            required: true %>
        <% if @minimum_password_length %>
          <p class="text-xs text-gray-500 mt-1">Минимум <%= @minimum_password_length %> символов</p>
        <% end %>
      </div>
      
      <!-- Подтверждение пароля -->
      <div>
        <%= f.label :password_confirmation, class: "block text-gray-700 font-semibold mb-2 flex items-center gap-2" do %>
          <span class="text-xl">✅</span>
          Подтвердите пароль
        <% end %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 transition-all",
            placeholder: "••••••••",
            required: true %>
      </div>
      
      <!-- Кнопка регистрации -->
      <div class="pt-4">
        <%= f.submit "Зарегистрироваться", 
            class: "w-full bg-gradient-to-r from-red-600 to-amber-600 text-white font-bold py-3 px-4 rounded-xl hover:from-red-700 hover:to-amber-700 transform hover:scale-[1.02] transition-all duration-200 shadow-lg cursor-pointer" %>
      </div>
    <% end %>
    
    <!-- Разделитель -->
    <div class="relative my-6">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t-2 border-gray-200"></div>
      </div>
      <div class="relative flex justify-center text-sm">
        <span class="px-3 bg-white text-gray-500">или</span>
      </div>
    </div>
    
    <!-- Ссылка на вход -->
    <div class="text-center space-y-3">
      <p class="text-gray-600">
        Уже есть аккаунт?
        <%= link_to "Войти", new_session_path(resource_name), 
            class: "text-red-600 font-semibold hover:text-red-700 hover:underline transition-all" %>
      </p>
      
      <%= link_to "← На главную", root_path, 
          class: "inline-block text-sm text-gray-500 hover:text-gray-700 transition-colors" %>
    </div>
  </div>
  
  <!-- Мясной футер -->
  <div class="bg-gray-50 px-6 py-3 text-center text-xs text-gray-500 border-t-2 border-gray-100">
    🥩 Вкусной шаурмы! 🥙
  </div>
</div>

<style>
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-5px); }
    75% { transform: translateX(5px); }
  }
  
  .animate-bounce {
    animation: bounce 1s ease-in-out infinite;
  }
  
  .animate-shake {
    animation: shake 0.3s ease-in-out;
  }
</style>