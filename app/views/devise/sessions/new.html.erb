<div class="bg-white rounded-2xl shadow-2xl overflow-hidden transform transition-all duration-300 hover:scale-[1.02]">
  <!-- Шапка -->
  <div class="bg-gradient-to-r from-amber-600 via-orange-600 to-red-600 px-6 py-8 text-center">
    <div class="text-7xl mb-3 animate-pulse">🌯</div>
    <h1 class="text-3xl font-bold text-white mb-2">Добро пожаловать!</h1>
    <p class="text-amber-100 text-sm">Войди, чтобы найти лучшую шаурму</p>
  </div>
  
  <!-- Форма входа -->
  <div class="p-6 md:p-8">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), 
        html: { class: "space-y-5" }) do |f| %>
      
      <!-- Email -->
      <div>
        <%= f.label :email, class: "block text-gray-700 font-semibold mb-2 flex items-center gap-2" do %>
          <span class="text-xl">📧</span>
          Email
        <% end %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all",
            placeholder: "your@email.com",
            required: true %>
      </div>
      
      <!-- Пароль -->
      <div>
        <%= f.label :password, class: "block text-gray-700 font-semibold mb-2 flex items-center gap-2" do %>
          <span class="text-xl">🔒</span>
          Пароль
        <% end %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full px-4 py-3 border-2 border-gray-200 rounded-xl focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-200 transition-all",
            placeholder: "••••••••",
            required: true %>
      </div>
      
      <!-- Запомнить меня -->
      <% if devise_mapping.rememberable? %>
        <div class="flex items-center justify-between">
          <label class="flex items-center gap-2 cursor-pointer">
            <%= f.check_box :remember_me, class: "w-4 h-4 text-orange-600 rounded border-gray-300 focus:ring-orange-500" %>
            <span class="text-sm text-gray-600">Запомнить меня</span>
          </label>
          
          <%= link_to "Забыли пароль?", new_password_path(resource_name),
              class: "text-sm text-orange-600 hover:text-orange-700 hover:underline" %>
        </div>
      <% end %>
      
      <!-- Кнопка входа -->
      <div class="pt-4">
        <%= f.submit "Войти", 
            class: "w-full bg-gradient-to-r from-amber-600 to-orange-600 text-white font-bold py-3 px-4 rounded-xl hover:from-amber-700 hover:to-orange-700 transform hover:scale-[1.02] transition-all duration-200 shadow-lg cursor-pointer" %>
      </div>
    <% end %>
    
    <!-- Разделитель -->
    <div class="relative my-6">
      <div class="absolute inset-0 flex items-center">
        <div class="w-full border-t-2 border-gray-200"></div>
      </div>
      <div class="relative flex justify-center text-sm">
        <span class="px-3 bg-white text-gray-500">впервые здесь?</span>
      </div>
    </div>
    
    <!-- Ссылка на регистрацию -->
    <div class="text-center space-y-3">
      <%= link_to "🍖 Создать новый аккаунт 🍖", new_registration_path(resource_name),
          class: "block w-full bg-gradient-to-r from-green-600 to-emerald-600 text-white font-bold py-3 px-4 rounded-xl hover:from-green-700 hover:to-emerald-700 transform hover:scale-[1.02] transition-all duration-200 shadow-md" %>
      
      <%= link_to "← На главную", root_path,
          class: "inline-block text-sm text-gray-500 hover:text-gray-700 transition-colors mt-4" %>
    </div>
  </div>
  
  <!-- Футер -->
  <div class="bg-gradient-to-r from-gray-50 to-orange-50 px-6 py-3 text-center text-xs text-gray-500 border-t-2 border-orange-100">
    🥙 Найди свою идеальную шаурму! 🥩
  </div>
</div>

<style>
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }
  
  .animate-pulse {
    animation: pulse 2s ease-in-out infinite;
  }
</style>