<!DOCTYPE html>
<html>
  <head>
    <title>Шаурма Трекер</title>
    <meta name="viewport" content="width=device-width,initial-scale=1, maximum-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  
  <body class="bg-gradient-to-br from-amber-50 via-orange-50 to-red-50 min-h-screen">
    <!-- Шапка (navbar) -->
    <%= render "layouts/navbar" %>
    
    <!-- Основной контент -->
    <main>
      <%= yield %>
    </main>
    
    <!-- Футер (подвал) - опционально -->
    <footer class="bg-gradient-to-r from-gray-900 via-gray-800 to-gray-900 mt-10 py-6 text-center text-sm border-t-4 border-red-600 shadow-lg">
  <div class="container mx-auto px-4">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
      
      <!-- Левая часть - лого -->
      <div class="flex items-center gap-3">
        <span class="text-3xl">🥩</span>
        <div>
          <span class="font-black text-lg tracking-wide text-amber-400">ШАУРМА ТРЕКЕР</span>
          <p class="text-gray-400 text-xs">Поиск идеальной шаурмы</p>
        </div>
      </div>
      
      <!-- Центр - ссылки -->
      <div class="flex gap-6 text-sm">
        <a href="/" class="text-gray-300 hover:text-amber-400 transition-colors">🏠 Главная</a>
        <a href="/places" class="text-gray-300 hover:text-amber-400 transition-colors">🥙 Все точки</a>
        <% if user_signed_in? %>
          <a href="/users/<%= current_user.id %>" class="text-gray-300 hover:text-amber-400 transition-colors">👤 Профиль</a>
        <% end %>
      </div>
      
      <!-- Правая часть - копирайт -->
      <div class="text-xs">
        <p class="text-gray-300">© 2026 Все права защищены 
  <span class="text-amber-500">(и соус тоже)</span>
  <a href="/frog" class="text-gray-500 hover:text-amber-400 transition-colors ml-1" style="text-decoration: none;">🐸</a>
</p>
        <p class="text-gray-500 mt-1 flex items-center justify-center gap-1">
          <span>Сделано с</span>
          <span class="text-red-500 animate-pulse">❤️</span>
          <span>и</span>
          <span class="text-amber-500">🥩</span>
          <span>в Ростове-на-Дону</span>
        </p>
      </div>
      
    </div>
  </div>
</footer>

<style>
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }
  .animate-pulse {
    animation: pulse 1s ease-in-out infinite;
    display: inline-block;
  }
</style>
  </body>
</html>