<!DOCTYPE html>
<html>
  <head>
    <title>Шаурма Трекер - Вход/Регистрация</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-screen bg-gradient-to-br from-amber-50 via-orange-50 to-red-50">
    <!-- На страницах входа/регистрации шапку НЕ показываем -->
    <div class="min-h-screen flex items-center justify-center p-4">
      <div class="w-full max-w-md">
        <!-- Кнопка назад на главную (маленькая, но полезная) -->
        <div class="mb-4 text-center">
          <%= link_to root_path, class: "text-amber-600 hover:text-amber-700 text-sm inline-flex items-center gap-1" do %>
            <span>←</span> На главную
          <% end %>
        </div>
        
        <%= yield %>
      </div>
    </div>
  </body>
</html>